# --- Runtime mode ---
MODE=development            # 'production' enables HTTPS on 443 + redirect server
PORT=3001

# --- Chain config ---
WILDCAT_NETWORK=mainnet     # 'mainnet' | 'sepolia'
# Defaults to the Wildcat mainnet archive node (baked into src/wildcat/config.ts) if unset.
RPC_URL=https://eth-main.hinterlight.net/

# --- Default definition ---
# A market counts as "in default" when its delinquency grace tracker has run this many
# days past the grace period: timeDelinquent >= delinquencyGracePeriod + (days * 86400).
# Evaluated live. Default: 90.
DEFAULT_BUFFER_DAYS=90

# Optional: pre-fill the borrower address on the frontend. Lenders still pick the market
# from that borrower's on-chain markets. Leave empty to let them enter a borrower.
# BORROWER_ADDRESS=

# Count queued/expired withdrawal-batch amounts toward a lender's owed total.
INCLUDE_WITHDRAWALS=true

# Ignore lender positions below this many wei of the underlying (dust filter).
MIN_OWED_WEI=0

# Read path: 'lens' (MarketLens.getMarketDataWithLenderStatus, default) or
# 'direct' (per-market currentState() + balanceOf — the verified fallback).
LENS_MODE=lens

# DEBUG (testing only): when true, any lender being checked is assumed to hold >=100 of the
# underlying in every market, so testers can exercise the claim-signing flow without a real
# position. Signatures are still verified normally. Leave unset/false in production.
# For a testing deployment, set this via a Preview-scoped env var (e.g. on Vercel) rather than
# committing it on — production stays debug-off while previews run debug-on. See DEPLOY_VERCEL.md.
# DEBUG_MODE=false

# Optional block override for reads (audit/testing). Unset => 'latest' (live).
# SNAPSHOT_BLOCK=

# --- Contract addresses ---
# Defaults for mainnet/sepolia are baked into src/wildcat/config.ts; override here if needed.
# ARCH_CONTROLLER=
# MARKET_LENS=
# HOOKS_FACTORY=
# MULTICALL3=   # canonical 0xcA11bde05977b3631167028862bE2a173976CA11 baked in; override only if your chain differs

# --- Output ---
# A successful submit verifies the signature and returns a copyable signed-claim proof.
# Nothing is persisted yet (no DB, no Sheets); export/email is future work.
