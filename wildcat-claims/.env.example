# --- Runtime mode ---
MODE=development            # 'production' enables HTTPS on 443 + redirect server
PORT=3001

# --- Chain config ---
WILDCAT_NETWORK=mainnet     # 'mainnet' | 'sepolia'
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# --- Incident scoping (per-market) ---
# The in-scope markets for this claim intake. Eligibility is evaluated ONLY against
# these. Comma- or whitespace-separated checksummed addresses. Leave empty to fall
# back to enumerating every registered market (pre-incident default).
SCOPED_MARKETS=

# A label that namespaces stored claims so separate incidents never collide.
INCIDENT_ID=default

# --- Eligibility threshold (timestamp) ---
# Eligibility answers "was this lender holding debt in a scoped market as of this
# instant?". Unix seconds OR an ISO-8601 date (e.g. 2026-06-01T00:00:00Z).
# Reads pin to the last block at/before it — REQUIRES AN ARCHIVE NODE for history.
# Leave unset to read at 'latest'.
ELIGIBILITY_TIMESTAMP=

# Explicit block override. If set, used directly and timestamp resolution is skipped.
# SNAPSHOT_BLOCK=

# Count queued/expired withdrawal-batch amounts toward a lender's owed total.
INCLUDE_WITHDRAWALS=true

# Ignore lender positions below this many wei of the underlying (dust filter).
MIN_OWED_WEI=0

# Read path: 'lens' (MarketLens.getMarketDataWithLenderStatus, default) or
# 'direct' (per-market currentState() + balanceOf — the verified fallback).
LENS_MODE=lens

# --- Contract addresses ---
# Defaults for mainnet/sepolia are baked into src/wildcat/config.ts; override here if needed.
# ARCH_CONTROLLER=
# MARKET_LENS=
# HOOKS_FACTORY=

# --- Google Sheets ---
# Service-account creds live in .google.json (gitignored): { client_email, private_key, sheet_id }
